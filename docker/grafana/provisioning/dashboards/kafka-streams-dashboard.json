{
    "uid":  "kafka-streams-demo",
    "title":  "Kafka Streams Demo",
    "timezone":  "browser",
    "schemaVersion":  38,
    "version":  2,
    "refresh":  "10s",
    "panels":  [
                   {
                       "type":  "row",
                       "title":  "Input Topic",
                       "collapsed":  false,
                       "gridPos":  {
                                       "x":  0,
                                       "y":  0,
                                       "w":  24,
                                       "h":  1
                                   }
                   },
                   {
                       "type":  "timeseries",
                       "title":  "Input vs Output Rate",
                       "datasource":  "Prometheus",
                       "targets":  [
                                       {
                                           "expr":  "rate(messages_consumed_total[1m])",
                                           "legendFormat":  "consumed/s"
                                       },
                                       {
                                           "expr":  "rate(messages_produced_total[1m])",
                                           "legendFormat":  "produced/s"
                                       }
                                   ],
                       "gridPos":  {
                                       "x":  0,
                                       "y":  1,
                                       "w":  12,
                                       "h":  8
                                   }
                   },
                   {
                       "type":  "timeseries",
                       "title":  "Consumer Group Lag (input-topic)",
                       "description":  "Total lag for the Streams consumer group",
                       "datasource":  "Prometheus",
                       "targets":  [
                                       {
                                           "expr":  "sum by (group) (kafka_consumer_group_lag_total{topic=\"input-topic\"})",
                                           "legendFormat":  "{{group}}"
                                       }
                                   ],
                       "gridPos":  {
                                       "x":  12,
                                       "y":  1,
                                       "w":  12,
                                       "h":  8
                                   }
                   },
                   {
                       "type":  "timeseries",
                       "title":  "Consumer Lag Change Rate",
                       "description":  "Positive means lag is growing; negative means catching up",
                       "datasource":  "Prometheus",
                       "targets":  [
                                       {
                                           "expr":  "sum by (group) (deriv(kafka_consumer_group_lag_total{topic=\"input-topic\"}[5m]))",
                                           "legendFormat":  "{{group}} lag/s"
                                       }
                                   ],
                       "gridPos":  {
                                       "x":  0,
                                       "y":  9,
                                       "w":  12,
                                       "h":  8
                                   }
                   },
                   {
                       "type":  "timeseries",
                       "title":  "Message Processing Latency (p95)",
                       "datasource":  "Prometheus",
                       "targets":  [
                                       {
                                           "expr":  "histogram_quantile(0.95, sum(rate(message_processing_latency_seconds_bucket[5m])) by (le))",
                                           "legendFormat":  "p95 seconds"
                                       }
                                   ],
                       "gridPos":  {
                                       "x":  12,
                                       "y":  9,
                                       "w":  12,
                                       "h":  8
                                   }
                   },
                   {
                       "type":  "timeseries",
                       "title":  "Message Processing Latency (p99)",
                       "datasource":  "Prometheus",
                       "targets":  [
                                       {
                                           "expr":  "histogram_quantile(0.99, sum(rate(message_processing_latency_seconds_bucket[5m])) by (le))",
                                           "legendFormat":  "p99 seconds"
                                       }
                                   ],
                       "gridPos":  {
                                       "x":  0,
                                       "y":  17,
                                       "w":  12,
                                       "h":  8
                                   }
                   },
                   {
                       "type":  "timeseries",
                       "title":  "End-to-End Avg Processing Time",
                       "description":  "Average processing time derived from the latency timer",
                       "datasource":  "Prometheus",
                       "targets":  [
                                       {
                                           "expr":  "rate(message_processing_latency_seconds_sum[5m]) / rate(message_processing_latency_seconds_count[5m])",
                                           "legendFormat":  "avg seconds"
                                       }
                                   ],
                       "gridPos":  {
                                       "x":  12,
                                       "y":  17,
                                       "w":  12,
                                       "h":  8
                                   }
                   },
                   {
                       "type":  "row",
                       "title":  "Kafka Streams",
                       "collapsed":  false,
                       "gridPos":  {
                                       "x":  0,
                                       "y":  25,
                                       "w":  24,
                                       "h":  1
                                   }
                   },
                   {
                       "type":  "timeseries",
                       "title":  "Kafka Streams Throughput",
                       "description":  "Kafka Streams process rate derived from process_total counter",
                       "datasource":  "Prometheus",
                       "targets":  [
                                       {
                                           "expr":  "label_replace(rate(kafka_stream_thread_process_total[1m]), \"thread_short\", \"$1\", \"thread_id\", \".*(StreamThread-[0-9]+)$\")",
